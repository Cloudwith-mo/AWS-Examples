#!/usr/bin/env bash
echo "== recieve"

root_path=$(realpath .)
message_attributes_path="file://${root_path}/send-message.json"

QUEUE_URL="https://sqs.us-east-1.amazonaws.com/114743615542/sqs-standard-MyQueue-813w5Up5AonT"


aws sqs receive-message \
  --queue-url $QUEUE_URL \
  --message-attribute-names All \s
  --max-number-of-messages 10